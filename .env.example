# Copie este arquivo para .env e configure os valores abaixo

# API key da Anthropic (usada pelas funcionalidades de IA)
VITE_ANTHROPIC_API_KEY=sua_api_key_aqui

# String de conexão do Postgres (local: rode um Postgres na sua máquina;
# no Railway isso é preenchido automaticamente ao adicionar um banco Postgres)
DATABASE_URL=postgresql://usuario:senha@localhost:5432/workout_db

# Segredo usado para assinar o token de sessão — gere uma string aleatória longa
# (ex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
APP_JWT_SECRET=troque_por_uma_string_aleatoria_longa

# Senha de acesso ao app (protege a API já que ela fica pública na internet)
APP_PASSWORD=escolha_uma_senha

# Porta do servidor local do backend (o frontend do Vite faz proxy pra ela em dev)
PORT=3001

# Chaves VAPID para notificações push (aviso quando o descanso termina, mesmo
# com a tela apagada). Gere um par com: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=chave_publica_vapid
VAPID_PRIVATE_KEY=chave_privada_vapid
